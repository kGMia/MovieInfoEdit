    "Cache Hint" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app records directors, genres and actors for quick autocomplete."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'app enregistre les réalisateurs, genres et actors pour la saisie automatique."
