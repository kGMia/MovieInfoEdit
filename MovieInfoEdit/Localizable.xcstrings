        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "監督・ジャンル・出演者の入力履歴を記録し、次回の入力補完に活用します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
