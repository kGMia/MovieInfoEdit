    "About Description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An elegant batch .NFO file editor developed for macOS."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un élégant éditeur de fichiers .NFO par lots conçu pour macOS."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "macOS 向けのエレガントなバッチ .NFO ファイルエディタ。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
